{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": false,
    "importHelpers": false,
    "esModuleInterop": true,
    "useDefineForClassFields": false,
    "outDir": "out-tsc"
  },
  "include": ["src/**/*.ts"],
  "angularCompilerOptions": {
    "compilationMode": "partial",
    "strictTemplates": true
  }
}
