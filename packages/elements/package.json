{
  "name": "@salkomdesignstudio/motion-forge-elements",
  "version": "1.0.0",
  "description": "Framework-free Web Components for SDS Motion Forge: <sds-motion> and <sds-text>. Vanilla TypeScript, zero dependencies, no shadow DOM (animations inherit page CSS).",
  "license": "MIT",
  "author": {
    "name": "Salkom Design Studio",
    "email": "hello@salkomdesignstudio.com",
    "url": "https://salkomdesignstudio.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salkomdesignstudio/SDS-Motion-Forge.git",
    "directory": "packages/elements"
  },
  "keywords": ["web-components", "custom-elements", "animation", "motion", "sds-motion-forge"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.global.js",
  "jsdelivr": "./dist/index.global.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./global": "./dist/index.global.js",
    "./package.json": "./package.json"
  },
  "engines": {
    "node": ">=18"
  },
  "files": ["dist/", "README.md"],
  "sideEffects": ["./dist/index.global.js"],
  "scripts": {
    "generate": "node scripts/generate.cjs",
    "build": "npm run generate && tsup",
    "validate": "publint"
  },
  "devDependencies": {
    "publint": "^0.3.21",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
