node_modules/
.npm-cache/
*.tgz
# Exception: the committed R1 baseline — the published-tarball contract.
!baseline/*.tgz
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.DS_Store
Thumbs.db

# Local docs build artifact — created by `cp -r dist docs/dist` for local preview.
# Netlify creates this during CI; do not commit it.
docs/dist/

# Example apps — installed/built locally and in CI smoke tests.
examples/*/node_modules/
examples/*/dist/
examples/nextjs/.next/
examples/nextjs/next-env.d.ts
examples/tailwind-v4/probe*.html
examples/tailwind-v4/probe*.css
examples/angular/.angular/

# Framework packages — generated build artifacts (rebuilt by npm run build -ws).
packages/*/dist/
packages/*/src/generated/
packages/*/out-tsc/

# Playwright artifacts. Committed: test/visual/__screenshots__/ (baselines).
test-results/
playwright-report/
# The fixture is generated from the registry on every run.
test/visual/fixture.html

# Generated JS build artifacts — produced by `npm run build:js` (terser).
# These are regenerated on every build; never edit them manually.
# They ARE included in the npm package (via "files": ["dist/"]) but not in git.
dist/sds-scroll.min.js
dist/sds-scroll.min.js.map
dist/motion-interactive.min.js
dist/motion-interactive.min.js.map
