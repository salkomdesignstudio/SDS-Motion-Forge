{
  "name": "@salkomdesignstudio/sds-motion-forge",
  "version": "5.0.0",
  "description": "600+ production-ready CSS animations for text, buttons, inputs, cards, loaders, and scroll. Zero required JavaScript.",
  "main": "./dist/motion.css",
  "style": "./dist/motion.css",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "style": "./dist/motion.css",
      "default": "./dist/motion.css"
    },
    "./dist/motion.css": "./dist/motion.css",
    "./dist/motion.min.css": "./dist/motion.min.css",
    "./dist/sds-scroll.min.js": "./dist/sds-scroll.min.js",
    "./dist/sds-scroll.min.js.map": "./dist/sds-scroll.min.js.map",
    "./dist/motion-interactive.min.js": "./dist/motion-interactive.min.js",
    "./dist/motion-interactive.min.js.map": "./dist/motion-interactive.min.js.map",
    "./motion.css": "./dist/motion.css",
    "./motion.min.css": "./dist/motion.min.css",
    "./categories/core": {
      "style": "./dist/categories/core.css",
      "default": "./dist/categories/core.css"
    },
    "./categories/text": {
      "style": "./dist/categories/text.css",
      "default": "./dist/categories/text.css"
    },
    "./categories/buttons": {
      "style": "./dist/categories/buttons.css",
      "default": "./dist/categories/buttons.css"
    },
    "./categories/inputs": {
      "style": "./dist/categories/inputs.css",
      "default": "./dist/categories/inputs.css"
    },
    "./categories/cards": {
      "style": "./dist/categories/cards.css",
      "default": "./dist/categories/cards.css"
    },
    "./categories/loaders": {
      "style": "./dist/categories/loaders.css",
      "default": "./dist/categories/loaders.css"
    },
    "./categories/scroll": {
      "style": "./dist/categories/scroll.css",
      "default": "./dist/categories/scroll.css"
    },
    "./dist/categories/core.css": "./dist/categories/core.css",
    "./dist/categories/core.min.css": "./dist/categories/core.min.css",
    "./dist/categories/text.css": "./dist/categories/text.css",
    "./dist/categories/text.min.css": "./dist/categories/text.min.css",
    "./dist/categories/buttons.css": "./dist/categories/buttons.css",
    "./dist/categories/buttons.min.css": "./dist/categories/buttons.min.css",
    "./dist/categories/inputs.css": "./dist/categories/inputs.css",
    "./dist/categories/inputs.min.css": "./dist/categories/inputs.min.css",
    "./dist/categories/cards.css": "./dist/categories/cards.css",
    "./dist/categories/cards.min.css": "./dist/categories/cards.min.css",
    "./dist/categories/loaders.css": "./dist/categories/loaders.css",
    "./dist/categories/loaders.min.css": "./dist/categories/loaders.min.css",
    "./dist/categories/scroll.css": "./dist/categories/scroll.css",
    "./dist/categories/scroll.min.css": "./dist/categories/scroll.min.css",
    "./registry/motion.registry.json": "./registry/motion.registry.json",
    "./tokens/motion.tokens.json": "./tokens/motion.tokens.json",
    "./tokens/figma.tokens.json": "./tokens/figma.tokens.json",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "src/",
    "registry/motion.registry.json",
    "tokens/motion.tokens.json",
    "tokens/figma.tokens.json",
    "tokens/sds-motion-tokens.ts",
    "index.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "./dist/motion.css",
    "./dist/motion.min.css",
    "**/*.css"
  ],
  "scripts": {
    "build:tokens": "node scripts/generate-tokens.js",
    "build:css": "postcss src/motion.css -o dist/motion.css && cleancss -o dist/motion.min.css dist/motion.css",
    "build:js": "terser src/sds-scroll.js -o dist/sds-scroll.min.js --compress --mangle --source-map \"url='sds-scroll.min.js.map'\" && terser src/motion-interactive.js -o dist/motion-interactive.min.js --compress --mangle --source-map \"url='motion-interactive.min.js.map'\"",
    "build:categories": "node scripts/build-categories.js",
    "build:packages": "npm run build --workspaces --if-present",
    "test:packages": "npm run test --workspaces --if-present",
    "generate:registry": "node scripts/generate-registry.js",
    "generate:docs": "node scripts/docs/generate-docs-data.js",
    "generate:samples": "node scripts/docs/generate-framework-samples.js",
    "build:docs-dist": "node -e \"const fs=require('fs'),p=require('path');const src='dist',dst='docs/dist';fs.rmSync(dst,{recursive:true,force:true});fs.cpSync(src,dst,{recursive:true});console.log('docs/dist synced')\"",
    "generate:og": "node scripts/generate-og-image.js",
    "build": "npm run build:tokens && npm run build:css && npm run build:js && npm run build:categories && npm run generate:registry && npm run generate:docs && npm run build:docs-dist",
    "build:dev": "postcss src/motion.css -o dist/motion.css --map",
    "build:watch": "postcss src/motion.css -o dist/motion.css --watch",
    "build:verify": "node verify-build.js",
    "verify:reduced-motion": "node scripts/verify-reduced-motion.js",
    "lint:css": "stylelint \"src/categories/*.css\"",
    "test:visual": "node scripts/visual/generate-fixture.js && playwright test --project=visual",
    "test:perf": "node scripts/visual/generate-fixture.js && playwright test --project=perf",
    "test:a11y": "playwright test --project=a11y",
    "test:docs": "playwright test --project=docs --project=builder",
    "verify:snippets": "node scripts/docs/setup-snippets-fixture.js && playwright test --project=snippets && node scripts/docs/verify-tailwind-utilities.js",
    "verify:docs": "node scripts/docs/generate-docs-data.js --check",
    "smoke:pack": "node scripts/smoke-pack-install.js",
    "verify:tokens": "node scripts/generate-tokens.js --check",
    "verify:registry": "node scripts/generate-registry.js --check",
    "verify:split": "node scripts/verify-split.js",
    "verify:published": "node scripts/verify-against-published.js",
    "validate": "publint",
    "pack:check": "npm pack --dry-run",
    "size": "size-limit",
    "release:check": "npm run build && npm run build:verify && npm run verify:tokens && npm run verify:registry && npm run verify:docs && npm run verify:split && npm run verify:published && npm run verify:reduced-motion && npm run lint:css && npm run size && npm run validate && npm run pack:check",
    "prepublishOnly": "npm run release:check"
  },
  "keywords": [
    "css",
    "animation",
    "css-animation",
    "animations",
    "motion",
    "gsap-alternative",
    "css-only",
    "angular",
    "react",
    "vue",
    "flutter",
    "nextjs",
    "ui",
    "frontend",
    "design-system",
    "zero-js",
    "transition",
    "keyframes",
    "animate"
  ],
  "author": {
    "name": "Salkom Design Studio",
    "email": "hello@salkomdesignstudio.com",
    "url": "https://salkomdesignstudio.com"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salkomdesignstudio/SDS-Motion-Forge.git"
  },
  "homepage": "https://github.com/salkomdesignstudio/SDS-Motion-Forge",
  "bugs": {
    "url": "https://github.com/salkomdesignstudio/SDS-Motion-Forge/issues"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "autoprefixer": "^10.4.18",
    "clean-css-cli": "^5.6.3",
    "http-server": "^14.1.1",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.1",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "stylelint": "^17.13.0",
    "terser": "^5.48.0"
  },
  "engines": {
    "node": ">=20"
  },
  "browserslist": [
    "> 0.5%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "unpkg": "./dist/motion.min.css",
  "jsdelivr": "./dist/motion.min.css"
}
