{
  "name": "@salkomdesignstudio/sds-motion-forge",
  "version": "3.2.0",
  "description": "Production-ready CSS animation library — 90+ class-based animations for text, buttons, inputs, cards, loaders, and scroll. No JavaScript required.",
  "type": "commonjs",
  "main": "./dist/motion.css",
  "style": "./dist/motion.css",
  "exports": {
    ".": "./dist/motion.css",
    "./motion.css": "./dist/motion.css",
    "./motion.min.css": "./dist/motion.min.css"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "postcss src/motion.css -o dist/motion.css && clean-css-cli -o dist/motion.min.css dist/motion.css",
    "build:dev": "postcss src/motion.css -o dist/motion.css --map",
    "build:watch": "postcss src/motion.css -o dist/motion.css --watch",
    "build:verify": "node verify-build.js",
    "validate": "publint",
    "prepublishOnly": "npm run build && npm run build:verify && npm run validate"
  },
  "keywords": [
    "css",
    "animations",
    "motion",
    "ui",
    "ux",
    "class-based",
    "tailwind",
    "angular",
    "react",
    "vue",
    "bootstrap",
    "scroll-animations",
    "loaders",
    "text-animations",
    "button-animations",
    "frontend",
    "design-system",
    "salkom",
    "sds-motion",
    "keyframes",
    "no-javascript",
    "pure-css"
  ],
  "author": {
    "name": "Salkom Design Studio",
    "email": "hello@salkomdesignstudio.com",
    "url": "https://salkomdesignstudio.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salkomdesignstudio/SDS-Motion-Forge.git"
  },
  "homepage": "https://github.com/salkomdesignstudio/SDS-Motion-Forge",
  "bugs": {
    "url": "https://github.com/salkomdesignstudio/SDS-Motion-Forge/issues"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.18",
    "clean-css-cli": "^5.6.3",
    "postcss": "^8.4.35",
    "postcss-cli": "^11.0.0",
    "publint": "^0.3.21"
  },
  "engines": {
    "node": ">=14"
  },
  "unpkg": "./dist/motion.min.css",
  "jsdelivr": "./dist/motion.min.css",
  "sideEffects": [
    "./dist/motion.css",
    "./dist/motion.min.css"
  ]
}
